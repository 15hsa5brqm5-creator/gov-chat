<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title>شات الحكومة | تسجيل الدخول</title>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Cairo', sans-serif;
            background: linear-gradient(135deg, #0a0a12 0%, #1a1a2e 100%);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }

        /* الخلفية المتحركة */
        .bg-animation {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 0;
            overflow: hidden;
        }

        .bg-animation span {
            position: absolute;
            width: 4px;
            height: 4px;
            background: rgba(126, 179, 17, 0.3);
            border-radius: 50%;
            animation: float 15s infinite linear;
        }

        @keyframes float {
            0% {
                transform: translateY(100vh) scale(0);
                opacity: 0;
            }
            10% {
                opacity: 1;
            }
            90% {
                opacity: 1;
            }
            100% {
                transform: translateY(-100vh) scale(1);
                opacity: 0;
            }
        }

        /* البطاقة الرئيسية */
        .login-container {
            position: relative;
            z-index: 1;
            width: 100%;
            max-width: 450px;
        }

        .logo-section {
            text-align: center;
            margin-bottom: 30px;
        }

        .gov-logo {
            width: 100px;
            height: 100px;
            margin: 0 auto 15px;
            background: linear-gradient(135deg, #7eb311, #5a8a0a);
            border-radius: 30px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 55px;
            box-shadow: 0 10px 40px rgba(126, 179, 17, 0.3);
            animation: glow 2s ease-in-out infinite alternate;
        }

        @keyframes glow {
            from {
                box-shadow: 0 10px 40px rgba(126, 179, 17, 0.3);
            }
            to {
                box-shadow: 0 10px 60px rgba(126, 179, 17, 0.6);
            }
        }

        .logo-section h1 {
            font-size: 2rem;
            background: linear-gradient(135deg, #fff, #7eb311);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            margin-bottom: 5px;
        }

        .logo-section .url {
            color: #7eb311;
            font-size: 0.85rem;
            opacity: 0.8;
        }

        /* بطاقة تسجيل الدخول */
        .card {
            background: rgba(26, 26, 46, 0.95);
            backdrop-filter: blur(10px);
            border-radius: 30px;
            padding: 30px 25px;
            border: 1px solid rgba(126, 179, 17, 0.3);
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
        }

        .tabs {
            display: flex;
            gap: 10px;
            margin-bottom: 30px;
            background: rgba(0, 0, 0, 0.3);
            border-radius: 50px;
            padding: 5px;
        }

        .tab {
            flex: 1;
            text-align: center;
            padding: 12px 0;
            border-radius: 50px;
            cursor: pointer;
            transition: all 0.3s;
            font-weight: 600;
            color: #888;
        }

        .tab.active {
            background: #7eb311;
            color: white;
            box-shadow: 0 4px 15px rgba(126, 179, 17, 0.4);
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-group label {
            display: block;
            margin-bottom: 8px;
            color: #ccc;
            font-size: 0.9rem;
        }

        .input-wrapper {
            position: relative;
        }

        .input-wrapper i {
            position: absolute;
            right: 15px;
            top: 50%;
            transform: translateY(-50%);
            font-size: 1.2rem;
            font-style: normal;
        }

        input, select {
            width: 100%;
            padding: 14px 45px 14px 15px;
            background: rgba(0, 0, 0, 0.5);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 50px;
            color: white;
            font-size: 1rem;
            transition: all 0.3s;
            font-family: 'Cairo', sans-serif;
        }

        input:focus, select:focus {
            outline: none;
            border-color: #7eb311;
            box-shadow: 0 0 10px rgba(126, 179, 17, 0.3);
        }

        .btn {
            width: 100%;
            padding: 14px;
            border: none;
            border-radius: 50px;
            font-size: 1.1rem;
            font-weight: bold;
            cursor: pointer;
            transition: all 0.3s;
            font-family: 'Cairo', sans-serif;
        }

        .btn-primary {
            background: linear-gradient(135deg, #7eb311, #5a8a0a);
            color: white;
            margin-bottom: 15px;
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 20px rgba(126, 179, 17, 0.4);
        }

        .btn-guest {
            background: rgba(255, 255, 255, 0.1);
            color: white;
            border: 1px solid rgba(255, 255, 255, 0.2);
        }

        .btn-guest:hover {
            background: rgba(255, 255, 255, 0.2);
        }

        .separator {
            text-align: center;
            margin: 20px 0;
            position: relative;
        }

        .separator::before {
            content: '';
            position: absolute;
            top: 50%;
            left: 0;
            right: 0;
            height: 1px;
            background: rgba(255, 255, 255, 0.1);
        }

        .separator span {
            background: #1a1a2e;
            padding: 0 15px;
            position: relative;
            color: #888;
            font-size: 0.85rem;
        }

        .guest-options {
            display: flex;
            gap: 10px;
            margin-top: 15px;
        }

        .guest-options input {
            flex: 1;
        }

        .guest-options button {
            width: auto;
            padding: 14px 20px;
            white-space: nowrap;
        }

        .alert {
            padding: 12px 15px;
            border-radius: 15px;
            margin-bottom: 20px;
            display: none;
        }

        .alert-error {
            background: rgba(220, 38, 38, 0.2);
            border: 1px solid #dc2626;
            color: #ff6b6b;
        }

        .alert-success {
            background: rgba(126, 179, 17, 0.2);
            border: 1px solid #7eb311;
            color: #7eb311;
        }

        .switch-text {
            text-align: center;
            margin-top: 20px;
            color: #888;
        }

        .switch-text a {
            color: #7eb311;
            text-decoration: none;
            cursor: pointer;
        }

        /* نافذة الزائر المنبثقة */
        .guest-modal {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.9);
            backdrop-filter: blur(10px);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 1000;
            visibility: hidden;
            opacity: 0;
            transition: all 0.3s;
        }

        .guest-modal.show {
            visibility: visible;
            opacity: 1;
        }

        .guest-modal-content {
            background: #1a1a2e;
            border-radius: 30px;
            padding: 30px;
            max-width: 350px;
            width: 90%;
            text-align: center;
            border: 1px solid #7eb311;
        }

        /* Spinnger التحميل */
        .spinner {
            display: none;
            width: 20px;
            height: 20px;
            border: 2px solid rgba(255, 255, 255, 0.3);
            border-top-color: white;
            border-radius: 50%;
            animation: spin 0.6s linear infinite;
            margin: 0 auto;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        /* التجاوب مع الجوال */
        @media (max-width: 500px) {
            .card {
                padding: 20px;
            }
            .guest-options {
                flex-direction: column;
            }
            .guest-options button {
                width: 100%;
            }
        }
    </style>
</head>
<body>

<div class="bg-animation" id="bgAnimation"></div>

<div class="login-container">
    <div class="logo-section">
        <div class="gov-logo">🏛️</div>
        <h1>شات الحكومة</h1>
        <div class="url">www.gov-chat.com</div>
    </div>

    <div class="card">
        <div class="tabs">
            <div class="tab active" data-tab="login">تسجيل الدخول</div>
            <div class="tab" data-tab="register">إنشاء حساب</div>
        </div>

        <!-- نموذج تسجيل الدخول -->
        <div id="loginForm">
            <div class="alert" id="loginAlert"></div>
            <div class="form-group">
                <label>👤 اسم المستخدم أو البريد</label>
                <div class="input-wrapper">
                    <input type="text" id="loginUsername" placeholder="أدخل اسم المستخدم أو البريد">
                </div>
            </div>
            <div class="form-group">
                <label>🔒 كلمة المرور</label>
                <div class="input-wrapper">
                    <input type="password" id="loginPassword" placeholder="••••••">
                </div>
            </div>
            <button class="btn btn-primary" onclick="login()">دخول</button>
            <button class="btn btn-guest" onclick="showGuestModal()">دخول كزائر</button>
        </div>

        <!-- نموذج التسجيل -->
        <div id="registerForm" style="display: none;">
            <div class="alert" id="registerAlert"></div>
            <div class="form-group">
                <label>👤 اسم المستخدم</label>
                <input type="text" id="regUsername" placeholder="3 أحرف على الأقل">
            </div>
            <div class="form-group">
                <label>📧 البريد الإلكتروني</label>
                <input type="email" id="regEmail" placeholder="example@mail.com">
            </div>
            <div class="form-group">
                <label>🔒 كلمة المرور</label>
                <input type="password" id="regPassword" placeholder="6 أحرف على الأقل">
            </div>
            <div class="form-group">
                <label>👤 الجنس</label>
                <select id="regGender">
                    <option value="">اختر</option>
                    <option value="ذكر">ذكر</option>
                    <option value="أنثى">أنثى</option>
                </select>
            </div>
            <div class="form-group">
                <label>📅 العمر</label>
                <input type="number" id="regAge" placeholder="18+">
            </div>
            <button class="btn btn-primary" onclick="register()">إنشاء حساب</button>
        </div>
    </div>

    <div class="switch-text">
        <span id="switchMsg"></span>
    </div>
</div>

<!-- نافذة الزائر -->
<div id="guestModal" class="guest-modal">
    <div class="guest-modal-content">
        <h3 style="color: #7eb311; margin-bottom: 20px;">🌸 دخول كزائر</h3>
        <input type="text" id="guestName" placeholder="أدخل اسمك المستعار" style="text-align: center; margin-bottom: 15px;">
        <button class="btn btn-primary" onclick="guestLogin()" style="margin-bottom: 10px;">دخول</button>
        <button class="btn btn-guest" onclick="closeGuestModal()" style="background: rgba(220,38,38,0.2); border-color: #dc2626;">إلغاء</button>
    </div>
</div>

<script>
    // خلفية متحركة بنقاط
    function createBackgroundStars() {
        const bg = document.getElementById('bgAnimation');
        const starCount = 100;
        for (let i = 0; i < starCount; i++) {
            const star = document.createElement('span');
            const size = Math.random() * 4 + 1;
            star.style.width = size + 'px';
            star.style.height = size + 'px';
            star.style.left = Math.random() * 100 + '%';
            star.style.animationDelay = Math.random() * 15 + 's';
            star.style.animationDuration = Math.random() * 10 + 8 + 's';
            bg.appendChild(star);
        }
    }
    createBackgroundStars();

    // التبديل بين التبويبات
    document.querySelectorAll('.tab').forEach(tab => {
        tab.addEventListener('click', () => {
            document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
            tab.classList.add('active');
            
            const isLogin = tab.getAttribute('data-tab') === 'login';
            document.getElementById('loginForm').style.display = isLogin ? 'block' : 'none';
            document.getElementById('registerForm').style.display = isLogin ? 'none' : 'block';
            
            // مسح التنبيهات
            document.getElementById('loginAlert').style.display = 'none';
            document.getElementById('registerAlert').style.display = 'none';
        });
    });

    function showAlert(element, message, type) {
        element.innerHTML = message;
        element.className = `alert alert-${type}`;
        element.style.display = 'block';
        setTimeout(() => {
            element.style.display = 'none';
        }, 4000);
    }

    async function login() {
        const username = document.getElementById('loginUsername').value.trim();
        const password = document.getElementById('loginPassword').value;
        const alertEl = document.getElementById('loginAlert');
        
        if (!username || !password) {
            showAlert(alertEl, '❌ الرجاء إدخال جميع البيانات', 'error');
            return;
        }
        
        try {
            const response = await fetch('/api/login', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ username, password })
            });
            const data = await response.json();
            
            if (data.success) {
                showAlert(alertEl, '✅ تم تسجيل الدخول بنجاح، جارٍ التحويل...', 'success');
                setTimeout(() => { window.location.href = '/chat'; }, 1000);
            } else {
                showAlert(alertEl, '❌ ' + data.error, 'error');
            }
        } catch (error) {
            showAlert(alertEl, '❌ خطأ في الاتصال بالخادم', 'error');
        }
    }

    async function register() {
        const username = document.getElementById('regUsername').value.trim();
        const email = document.getElementById('regEmail').value.trim();
        const password = document.getElementById('regPassword').value;
        const gender = document.getElementById('regGender').value;
        const age = document.getElementById('regAge').value;
        const alertEl = document.getElementById('registerAlert');
        
        if (!username || !email || !password) {
            showAlert(alertEl, '❌ الرجاء ملء جميع الحقول المطلوبة', 'error');
            return;
        }
        
        if (username.length < 3) {
            showAlert(alertEl, '❌ اسم المستخدم يجب أن يكون 3 أحرف على الأقل', 'error');
            return;
        }
        
        if (password.length < 6) {
            showAlert(alertEl, '❌ كلمة المرور يجب أن تكون 6 أحرف على الأقل', 'error');
            return;
        }
        
        try {
            const response = await fetch('/api/register', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ username, email, password, gender, age })
            });
            const data = await response.json();
            
            if (data.success) {
                showAlert(alertEl, '✅ تم إنشاء الحساب بنجاح، جارٍ التحويل...', 'success');
                setTimeout(() => { window.location.href = '/chat'; }, 1000);
            } else {
                showAlert(alertEl, '❌ ' + data.error, 'error');
            }
        } catch (error) {
            showAlert(alertEl, '❌ خطأ في الاتصال بالخادم', 'error');
        }
    }

    function showGuestModal() {
        document.getElementById('guestModal').classList.add('show');
        document.getElementById('guestName').value = '';
    }

    function closeGuestModal() {
        document.getElementById('guestModal').classList.remove('show');
    }

    async function guestLogin() {
        let guestName = document.getElementById('guestName').value.trim();
        if (!guestName) {
            guestName = 'زائر_' + Math.floor(Math.random() * 10000);
        }
        
        // منع الأحرف غير المسموحة
        guestName = guestName.replace(/[^\u0621-\u064A\w\s]/g, '').substring(0, 15);
        
        try {
            const response = await fetch('/api/guest-login', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ username: guestName })
            });
            const data = await response.json();
            
            if (data.success) {
                window.location.href = '/chat';
            } else {
                alert('خطأ: ' + data.error);
            }
        } catch (error) {
            alert('خطأ في الاتصال بالخادم');
        }
    }

    // الضغط على Enter
    document.getElementById('loginPassword')?.addEventListener('keypress', (e) => {
        if (e.key === 'Enter') login();
    });
    document.getElementById('regPassword')?.addEventListener('keypress', (e) => {
        if (e.key === 'Enter') register();
    });
    
    // إذا كان المستخدم مسجلاً دخوله مسبقاً، التوجيه للشات
    fetch('/api/user/stats').then(res => {
        if (res.status === 200) {
            window.location.href = '/chat';
        }
    }).catch(() => {});
</script>
</body>
</html>
