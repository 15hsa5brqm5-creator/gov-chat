<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title>شات الحكومة | الدردشة الرئيسية</title>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="manifest" href="/static/manifest.json">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --primary: #7eb311;
            --primary-dark: #5a8a0a;
            --bg-dark: #0a0a12;
            --bg-card: #1a1a2e;
            --bg-input: #2a2a3e;
            --text: #ffffff;
            --text-muted: #888;
            --danger: #dc2626;
            --warning: #f59e0b;
            --success: #10b981;
        }

        body {
            font-family: 'Cairo', sans-serif;
            background: var(--bg-dark);
            color: var(--text);
            height: 100vh;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        /* ========== الشريط العلوي ========== */
        .top-bar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 10px 16px;
            background: var(--bg-card);
            border-bottom: 1px solid rgba(126, 179, 17, 0.3);
        }

        .left-icons, .right-icons {
            display: flex;
            gap: 15px;
            align-items: center;
        }

        .icon-btn {
            background: none;
            border: none;
            font-size: 24px;
            cursor: pointer;
            color: var(--primary);
            padding: 8px;
            transition: 0.2s;
            border-radius: 12px;
        }

        .icon-btn:hover {
            background: rgba(126, 179, 17, 0.1);
            transform: scale(1.05);
        }

        .diamond-box {
            display: flex;
            flex-direction: column;
            align-items: center;
            cursor: pointer;
            background: rgba(126, 179, 17, 0.15);
            padding: 5px 12px;
            border-radius: 25px;
            transition: 0.2s;
        }

        .diamond-box:hover {
            background: rgba(126, 179, 17, 0.3);
        }

        .diamond-box span:first-child {
            font-size: 20px;
        }

        .diamond-box span:last-child {
            font-size: 10px;
            color: var(--primary);
        }

        .profile-img {
            width: 44px;
            height: 44px;
            background: var(--bg-input);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            cursor: pointer;
            border: 2px solid var(--primary);
            transition: 0.2s;
        }

        .profile-img:hover {
            transform: scale(1.05);
        }

        /* ========== منطقة الرسائل ========== */
        .messages-container {
            flex: 1;
            overflow-y: auto;
            padding: 16px;
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .message {
            display: flex;
            gap: 10px;
            max-width: 85%;
            animation: fadeIn 0.2s ease;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .message.own {
            align-self: flex-end;
            flex-direction: row-reverse;
        }

        .message-avatar {
            width: 36px;
            height: 36px;
            background: var(--bg-input);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            flex-shrink: 0;
        }

        .bubble {
            background: var(--bg-input);
            padding: 10px 16px;
            border-radius: 20px;
            max-width: 100%;
        }

        .message.own .bubble {
            background: var(--primary);
        }

        .message-name {
            font-size: 12px;
            font-weight: bold;
            margin-bottom: 4px;
        }

        .message-text {
            font-size: 14px;
            word-break: break-word;
        }

        .message-time {
            font-size: 10px;
            color: var(--text-muted);
            margin-top: 4px;
            text-align: left;
        }

        .system-msg {
            text-align: center;
            background: rgba(126, 179, 17, 0.1);
            padding: 6px 12px;
            border-radius: 20px;
            font-size: 12px;
            width: fit-content;
            margin: 4px auto;
            color: var(--primary);
        }

        .typing-indicator {
            display: none;
            align-items: center;
            gap: 8px;
            padding: 8px 16px;
            background: var(--bg-input);
            border-radius: 20px;
            width: fit-content;
            font-size: 12px;
            color: var(--text-muted);
        }

        .typing-dots {
            display: flex;
            gap: 3px;
        }

        .typing-dots span {
            width: 6px;
            height: 6px;
            background: var(--primary);
            border-radius: 50%;
            animation: typing 1.4s infinite;
        }

        .typing-dots span:nth-child(2) { animation-delay: 0.2s; }
        .typing-dots span:nth-child(3) { animation-delay: 0.4s; }

        @keyframes typing {
            0%, 60%, 100% { transform: translateY(0); opacity: 0.4; }
            30% { transform: translateY(-6px); opacity: 1; }
        }

        /* ========== شريط الإدخال ========== */
        .input-bar {
            display: flex;
            gap: 8px;
            padding: 12px;
            background: var(--bg-card);
            border-top: 1px solid rgba(126, 179, 17, 0.3);
        }

        .input-icon {
            background: var(--bg-input);
            border: none;
            width: 48px;
            height: 48px;
            border-radius: 50%;
            font-size: 22px;
            cursor: pointer;
            transition: 0.2s;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .input-icon:hover {
            background: var(--primary);
            transform: scale(1.05);
        }

        .send-icon {
            background: var(--primary);
        }

        .message-input {
            flex: 1;
            background: var(--bg-input);
            border: none;
            border-radius: 40px;
            padding: 0 20px;
            color: white;
            font-size: 16px;
            font-family: 'Cairo', sans-serif;
        }

        .message-input:focus {
            outline: none;
            border: 1px solid var(--primary);
        }

        /* ========== الشريط السفلي ========== */
        .bottom-nav {
            display: flex;
            justify-content: space-around;
            background: var(--bg-card);
            padding: 8px 12px;
            border-top: 1px solid rgba(126, 179, 17, 0.3);
        }

        .nav-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            cursor: pointer;
            font-size: 22px;
            gap: 4px;
            padding: 5px 12px;
            border-radius: 20px;
            transition: 0.2s;
        }

        .nav-item:hover {
            background: rgba(126, 179, 17, 0.1);
        }

        .nav-item span {
            font-size: 10px;
            color: var(--text-muted);
        }

        /* ========== القائمة الجانبية ========== */
        .sidebar {
            position: fixed;
            top: 0;
            right: -300px;
            width: 280px;
            height: 100%;
            background: var(--bg-card);
            transition: 0.3s;
            z-index: 1000;
            padding: 20px;
            border-left: 1px solid var(--primary);
            overflow-y: auto;
        }

        .sidebar.open {
            right: 0;
        }

        .sidebar-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            padding-bottom: 10px;
            border-bottom: 1px solid rgba(126, 179, 17, 0.3);
        }

        .close-sidebar {
            background: none;
            border: none;
            font-size: 24px;
            color: var(--primary);
            cursor: pointer;
        }

        .sidebar-item {
            display: flex;
            align-items: center;
            gap: 15px;
            padding: 14px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
            cursor: pointer;
            border-radius: 15px;
            transition: 0.2s;
        }

        .sidebar-item:hover {
            background: rgba(126, 179, 17, 0.1);
        }

        /* ========== النوافذ المنبثقة العامة ========== */
        .modal {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.9);
            backdrop-filter: blur(8px);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 1200;
        }

        .modal.show {
            display: flex;
        }

        .modal-content {
            background: var(--bg-card);
            border-radius: 28px;
            width: 90%;
            max-width: 500px;
            max-height: 80vh;
            overflow-y: auto;
            padding: 20px;
            border: 1px solid var(--primary);
        }

        .modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid var(--primary);
            padding-bottom: 12px;
            margin-bottom: 15px;
        }

        .modal-header h3 {
            color: var(--primary);
        }

        .close-modal {
            background: none;
            border: none;
            font-size: 28px;
            cursor: pointer;
            color: var(--primary);
        }

        /* ========== يوتيوب منبثق ========== */
        .youtube-modal {
            max-width: 700px;
        }

        .youtube-search {
            display: flex;
            gap: 10px;
            margin-bottom: 15px;
        }

        .youtube-search input {
            flex: 1;
            padding: 10px;
            border-radius: 25px;
            border: none;
            background: var(--bg-input);
            color: white;
        }

        .youtube-results {
            max-height: 400px;
            overflow-y: auto;
        }

        .youtube-video {
            display: flex;
            gap: 10px;
            padding: 10px;
            cursor: pointer;
            border-radius: 15px;
            transition: 0.2s;
        }

        .youtube-video:hover {
            background: rgba(126, 179, 17, 0.1);
        }

        .youtube-video img {
            width: 120px;
            border-radius: 10px;
        }

        .youtube-video-info h4 {
            font-size: 14px;
            margin-bottom: 5px;
        }

        .youtube-video-info p {
            font-size: 12px;
            color: var(--text-muted);
        }

        .video-player {
            margin-top: 15px;
            display: none;
        }

        .video-player iframe {
            width: 100%;
            height: 250px;
            border-radius: 15px;
        }

        /* ========== التواجدين ========== */
        .users-list {
            max-height: 400px;
            overflow-y: auto;
        }

        .user-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
            cursor: pointer;
            border-radius: 15px;
        }

        .user-item:hover {
            background: rgba(126, 179, 17, 0.1);
        }

        .user-status {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: var(--success);
        }

        /* ========== المسابقات ========== */
        .contest-question {
            background: rgba(126, 179, 17, 0.1);
            padding: 15px;
            border-radius: 20px;
            margin-bottom: 15px;
        }

        .contest-answer {
            display: flex;
            gap: 10px;
            margin-top: 10px;
        }

        .contest-answer input {
            flex: 1;
            padding: 10px;
            border-radius: 25px;
            border: none;
            background: var(--bg-input);
            color: white;
        }

        /* ========== إعدادات الصوت ========== */
        .settings-section {
            margin-bottom: 20px;
        }

        .settings-section h4 {
            color: var(--primary);
            margin-bottom: 10px;
        }

        .toggle-switch {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 8px 0;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        }

        .toggle-input {
            width: 44px;
            height: 24px;
            background: var(--bg-input);
            border-radius: 30px;
            position: relative;
            cursor: pointer;
        }

        .toggle-input.active {
            background: var(--primary);
        }

        .toggle-input::after {
            content: '';
            position: absolute;
            width: 20px;
            height: 20px;
            background: white;
            border-radius: 50%;
            top: 2px;
            left: 2px;
            transition: 0.2s;
        }

        .toggle-input.active::after {
            left: 22px;
        }

        /* ========== رفع الملفات ========== */
        #fileInput {
            display: none;
        }

        /* ========== التسجيل الصوتي ========== */
        .voice-recording {
            display: none;
            align-items: center;
            gap: 10px;
            padding: 10px;
            background: var(--bg-input);
            border-radius: 40px;
            margin-top: 10px;
        }

        .recording-animation {
            width: 12px;
            height: 12px;
            background: red;
            border-radius: 50%;
            animation: pulse 1s infinite;
        }

        @keyframes pulse {
            0% { opacity: 1; transform: scale(1); }
            100% { opacity: 0; transform: scale(1.5); }
        }

        /* ========== إشعارات منبثقة ========== */
        .toast-notification {
            position: fixed;
            bottom: 20px;
            left: 20px;
            background: var(--bg-card);
            border-right: 4px solid var(--primary);
            padding: 12px 20px;
            border-radius: 15px;
            display: flex;
            align-items: center;
            gap: 12px;
            z-index: 1300;
            animation: slideIn 0.3s ease;
            box-shadow: 0 5px 20px rgba(0,0,0,0.3);
        }

        @keyframes slideIn {
            from { transform: translateX(-100%); opacity: 0; }
            to { transform: translateX(0); opacity: 1; }
        }

        /* ========== التمرير ========== */
        ::-webkit-scrollbar {
            width: 5px;
        }

        ::-webkit-scrollbar-track {
            background: var(--bg-input);
        }

        ::-webkit-scrollbar-thumb {
            background: var(--primary);
            border-radius: 10px;
        }
    </style>
</head>
<body>

<div style="display: flex; flex-direction: column; height: 100%;">
    <!-- الشريط العلوي -->
    <div class="top-bar">
        <div class="left-icons">
            <button class="icon-btn" id="menuBtn">☰</button>
            <div class="diamond-box" id="diamondBtn">
                <span>💎</span>
                <span>الكبار</span>
            </div>
        </div>
        <div class="right-icons">
            <button class="icon-btn" id="notifBtn">🔔</button>
            <div class="profile-img" id="profileBtn">
                <span id="profileEmoji">👤</span>
            </div>
        </div>
    </div>

    <!-- منطقة الرسائل -->
    <div class="messages-container" id="messagesContainer">
        <div class="system-msg">✨ مرحباً بك في شات الحكومة ✨</div>
        <div class="typing-indicator" id="typingIndicator">
            <span>يكتب...</span>
            <div class="typing-dots">
                <span></span><span></span><span></span>
            </div>
        </div>
    </div>

    <!-- شريط الإدخال -->
    <div class="input-bar">
        <button class="input-icon" id="attachBtn" title="رفع ملف">➕</button>
        <button class="input-icon" id="youtubeBtn" title="يوتيوب">▶️</button>
        <button class="input-icon" id="voiceBtn" title="تسجيل صوتي">🎤</button>
        <input type="text" class="message-input" id="messageInput" placeholder="اكتب رسالتك...">
        <button class="input-icon send-icon" id="sendBtn">📨</button>
    </div>
    <div class="voice-recording" id="voiceRecording">
        <div class="recording-animation"></div>
        <span>جاري التسجيل...</span>
        <button class="icon-btn" id="stopRecordingBtn" style="background: var(--danger); font-size: 14px;">إيقاف</button>
    </div>

    <!-- الشريط السفلي -->
    <div class="bottom-nav">
        <div class="nav-item" data-modal="membersModal">👥<span>المتواجدين</span></div>
        <div class="nav-item" data-modal="roomsModal">🏠<span>الغرف</span></div>
        <div class="nav-item" data-modal="shopModal">🛒<span>المتجر</span></div>
        <div class="nav-item" id="registerNavBtn" style="display: none;">📝<span>التسجيل</span></div>
        <div class="nav-item" data-modal="radioModal">📻<span>الراديو</span></div>
        <div class="nav-item" id="settingsBtn">⚙️<span>الإعدادات</span></div>
    </div>
</div>

<!-- ========== القائمة الجانبية ========== -->
<div id="sidebar" class="sidebar">
    <div class="sidebar-header">
        <h3 style="color: var(--primary);">القائمة</h3>
        <button class="close-sidebar" id="closeSidebar">✕</button>
    </div>
    <div class="sidebar-item" data-modal="roomsModal">🏠 الرومات</div>
    <div class="sidebar-item" data-modal="newsModal">📰 الأخبار</div>
    <div class="sidebar-item" data-modal="richModal">💎 الأثرياء (جواهر)</div>
    <div class="sidebar-item" data-modal="membersInteractionModal">👥 تفاعل الأعضاء</div>
    <div class="sidebar-item" data-modal="roomsInteractionModal">🚪 تفاعل الرومات</div>
    <div class="sidebar-item" data-modal="shopModal">🛒 متجر الشات</div>
    <div class="sidebar-item" data-modal="contestPointsModal">🏆 نقاط المسابقات</div>
    <div class="sidebar-item" data-modal="contestModal">🎮 المسابقات</div>
    <div class="sidebar-item" id="adminPanelBtn" style="display: none;">👑 لوحة المالك</div>
</div>

<!-- باقي النوافذ المنبثقة (سيتم إكمالها في الجزء الثاني) -->
<!-- ========== النوافذ المنبثقة ========== -->

<!-- نافذة الكبار (الأثرياء بالذهب) -->
<div id="diamondModal" class="modal">
    <div class="modal-content">
        <div class="modal-header">
            <h3>💎 كبار الشات (الذهب)</h3>
            <button class="close-modal" data-close="diamondModal">&times;</button>
        </div>
        <div id="richListGold">جاري التحميل...</div>
    </div>
</div>

<!-- نافذة الإشعارات -->
<div id="notifModal" class="modal">
    <div class="modal-content">
        <div class="modal-header">
            <h3>🔔 الإشعارات</h3>
            <button class="close-modal" data-close="notifModal">&times;</button>
        </div>
        <div id="notificationsList" style="max-height: 400px; overflow-y: auto;">جاري التحميل...</div>
    </div>
</div>

<!-- نافذة الملف الشخصي -->
<div id="profileModal" class="modal">
    <div class="modal-content">
        <div class="modal-header">
            <h3>👤 حسابي</h3>
            <button class="close-modal" data-close="profileModal">&times;</button>
        </div>
        <div id="profileContent">
            <div class="sidebar-item" data-modal="walletModal">💰 محفظتي</div>
            <div class="sidebar-item" data-modal="editProfileModal">✏️ تحرير الملف الشخصي</div>
            <div class="sidebar-item" data-modal="friendsModal">👥 أصدقائي</div>
            <div class="sidebar-item" data-modal="giftsReceivedModal">🎁 الهدايا المستلمة</div>
            <div class="sidebar-item" id="refreshPageBtn">🔄 تحديث الصفحة</div>
            <div class="sidebar-item" id="logoutBtn">🚪 خروج</div>
        </div>
    </div>
</div>

<!-- نافذة المحفظة -->
<div id="walletModal" class="modal">
    <div class="modal-content">
        <div class="modal-header">
            <h3>💰 محفظتي</h3>
            <button class="close-modal" data-close="walletModal">&times;</button>
        </div>
        <div style="text-align: center; padding: 20px;">
            <div style="font-size: 48px;">🪙</div>
            <div id="walletGold" style="font-size: 24px; color: var(--primary);">0</div>
            <div>الذهب</div>
            <div style="margin-top: 15px; font-size: 48px;">💎</div>
            <div id="walletGems" style="font-size: 24px; color: var(--primary);">0</div>
            <div>الجواهر</div>
            <button class="btn btn-primary" style="margin-top: 20px;" onclick="openModal('shopModal')">🛒 الذهاب للمتجر</button>
        </div>
    </div>
</div>

<!-- نافذة تحرير الملف الشخصي -->
<div id="editProfileModal" class="modal">
    <div class="modal-content">
        <div class="modal-header">
            <h3>✏️ تحرير الملف الشخصي</h3>
            <button class="close-modal" data-close="editProfileModal">&times;</button>
        </div>
        <div>
            <label>العمر</label>
            <input type="number" id="editAge" class="message-input" style="width: 100%; margin: 10px 0; padding: 10px;">
            <label>الجنس</label>
            <select id="editGender" class="message-input" style="width: 100%; margin: 10px 0; padding: 10px;">
                <option value="ذكر">ذكر</option>
                <option value="أنثى">أنثى</option>
            </select>
            <label>حالتي</label>
            <input type="text" id="editStatus" class="message-input" style="width: 100%; margin: 10px 0; padding: 10px;" placeholder="اكتب حالتك...">
            <label>لون الاسم</label>
            <input type="color" id="editNameColor" style="width: 100%; margin: 10px 0;">
            <button class="btn btn-primary" onclick="saveProfile()" style="width: 100%;">💾 حفظ التغييرات</button>
            <div class="system-msg" style="margin-top: 10px;">⚠️ لا يمكن تغيير الجنس والعمر إلا مرة واحدة</div>
        </div>
    </div>
</div>

<!-- نافذة الأصدقاء -->
<div id="friendsModal" class="modal">
    <div class="modal-content">
        <div class="modal-header">
            <h3>👥 أصدقائي</h3>
            <button class="close-modal" data-close="friendsModal">&times;</button>
        </div>
        <div id="friendsList">جاري التحميل...</div>
        <div class="sidebar-item" data-modal="friendRequestsModal">📨 طلبات الصداقة</div>
    </div>
</div>

<!-- نافذة طلبات الصداقة -->
<div id="friendRequestsModal" class="modal">
    <div class="modal-content">
        <div class="modal-header">
            <h3>📨 طلبات الصداقة</h3>
            <button class="close-modal" data-close="friendRequestsModal">&times;</button>
        </div>
        <div id="friendRequestsList">جاري التحميل...</div>
    </div>
</div>

