        <button class="btn btn-primary" id="sendImageBtn">📨 إرسال الصورة</button>
    </div>
</div>

<script src="https://cdn.socket.io/4.5.4/socket.io.min.js"></script>
<script>
    // ========== المتغيرات العامة ==========
    let socket = null;
    let currentRoom = 'main';
    let currentUser = null;
    let typingTimeout = null;
    let mediaRecorder = null;
    let audioChunks = [];
    let currentGiftTarget = null;
    let currentPrivateChatTarget = null;
    let pendingImage = null;
    
    // ========== تهيئة Socket.IO ==========
    function initSocket() {
        socket = io();
        
        socket.on('connect', () => {
            console.log('✅ متصل بالخادم');
            joinRoom(currentRoom);
        });
        
        socket.on('new_message', (data) => {
            addMessageToChat(data.username, data.message, data.time, data.user_role, data.name_color);
            playSound('public');
        });
        
        socket.on('user_joined', (data) => {
            addSystemMessage(data.message);
            playSound('public');
        });
        
        socket.on('user_left', (data) => {
            addSystemMessage(data.message);
        });
        
        socket.on('user_typing', (data) => {
            if (data.is_typing) {
                showTypingIndicator(data.username);
            } else {
                hideTypingIndicator();
            }
        });
        
        socket.on('private_message_received', (data) => {
            addPrivateNotification(data.from, data.message);
            playSound('private');
        });
        
        socket.on('gold_update', (data) => {
            updateWalletDisplay();
        });
        
        socket.on('gems_update', (data) => {
            updateWalletDisplay();
        });
        
        socket.on('new_notification', (data) => {
            showToast(data.title, data.content);
            loadNotifications();
        });
        
        socket.on('rank_updated', (data) => {
            showToast('🎖️ ترقية', `تمت ترقيتك إلى رتبة ${data.new_role}`);
            loadUserStats();
        });
        
        socket.on('system_message', (data) => {
            addSystemMessage(data.message);
        });
        
        socket.on('error', (data) => {
            showToast('❌ خطأ', data.message);
        });
    }
    
    // ========== دوال الدردشة ==========
    function joinRoom(roomName) {
        if (socket) {
            socket.emit('leave', { room: currentRoom });
            socket.emit('join', { room: roomName });
            currentRoom = roomName;
            document.getElementById('messagesContainer').innerHTML = '<div class="system-msg">✨ جاري تحميل المحادثة... ✨</div>';
            loadRoomMessages(roomName);
        }
    }
    
    function sendMessage() {
        const input = document.getElementById('messageInput');
        const message = input.value.trim();
        if (message) {
            socket.emit('send_message', { room: currentRoom, message: message });
            input.value = '';
            hideTypingIndicator();
        }
    }
    
    function sendPrivateMessage(toUsername, message) {
        socket.emit('private_message', { to: toUsername, message: message });
    }
    
    function sendTyping() {
        socket.emit('typing', { room: currentRoom, is_typing: true });
        if (typingTimeout) clearTimeout(typingTimeout);
        typingTimeout = setTimeout(() => {
            socket.emit('typing', { room: currentRoom, is_typing: false });
        }, 1000);
    }
    
    function addMessageToChat(username, message, time, role, nameColor) {
        const container = document.getElementById('messagesContainer');
        const isOwn = username === currentUser?.username;
        const messageDiv = document.createElement('div');
        messageDiv.className = `message ${isOwn ? 'own' : ''}`;
        messageDiv.innerHTML = `
            <div class="message-avatar">${getRoleIcon(role)}</div>
            <div class="bubble">
                <div class="message-name" style="color: ${nameColor || '#fff'}">${escapeHtml(username)}</div>
                <div class="message-text">${formatMessage(message)}</div>
                <div class="message-time">${time}</div>
            </div>
        `;
        container.appendChild(messageDiv);
        scrollToBottom();
    }
    
    function addSystemMessage(message) {
        const container = document.getElementById('messagesContainer');
        const msgDiv = document.createElement('div');
        msgDiv.className = 'system-msg';
        msgDiv.innerHTML = message;
        container.appendChild(msgDiv);
        scrollToBottom();
    }
    
    function addPrivateNotification(from, message) {
        showToast(`📨 رسالة خاصة من ${from}`, message.substring(0, 50));
    }
    
    function formatMessage(text) {
        // تحويل الروابط
        text = text.replace(/(https?:\/\/[^\s]+)/g, '<a href="$1" target="_blank" style="color: #7eb311;">$1</a>');
        // تحويل اليوتيوب تلقائياً
        text = text.replace(/(?:https?:\/\/)?(?:www\.)?(?:youtube\.com\/watch\?v=|youtu\.be\/)([^\s&]+)/g, 
            '<a href="#" onclick="playYouTubeVideo(\'$1\'); return false;" style="color: #ff0000;">▶️ تشغيل الفيديو</a>');
        return text;
    }
    
    function escapeHtml(text) {
        const div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML;
    }
    
    function scrollToBottom() {
        const container = document.getElementById('messagesContainer');
        container.scrollTop = container.scrollHeight;
    }
    
    function getRoleIcon(role) {
        const icons = {
            'owner': '👑',
            'super_admin': '⭐',
            'admin': '🛡️',
            'host': '🎯',
            'premium': '💎',
            'member_100': '🌟',
            'member_50': '✨',
            'member_25': '⭐',
            'member_10': '🔹',
            'member_1': '🔸',
            'visitor': '👤'
        };
        return icons[role] || '👤';
    }
    
    // ========== دوال الصوت ==========
    function playSound(type) {
        // سيتم تفعيل بناءً على إعدادات المستخدم
        const settings = JSON.parse(localStorage.getItem('soundSettings') || '{}');
        if (type === 'public' && settings.soundPublic === false) return;
        if (type === 'private' && settings.soundPrivate === false) return;
        
        const audio = new Audio();
        if (type === 'public') audio.src = 'https://www.soundjay.com/misc/sounds/bell-ringing-05.mp3';
        if (type === 'private') audio.src = 'https://www.soundjay.com/misc/sounds/message-received-1.mp3';
        audio.volume = 0.3;
        audio.play().catch(e => console.log('صوت محظور'));
    }
    
    // ========== التسجيل الصوتي ==========
    async function startVoiceRecording() {
        try {
            const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
            mediaRecorder = new MediaRecorder(stream);
            audioChunks = [];
            
            mediaRecorder.ondataavailable = (event) => {
                audioChunks.push(event.data);
            };
            
            mediaRecorder.onstop = async () => {
                const audioBlob = new Blob(audioChunks, { type: 'audio/webm' });
                const formData = new FormData();
                formData.append('audio', audioBlob, 'voice.webm');
                formData.append('room', currentRoom);
                
                const response = await fetch('/api/send-voice', {
                    method: 'POST',
                    body: formData
                });
                
                if (response.ok) {
                    addSystemMessage('🎙️ تم إرسال رسالة صوتية');
                }
                stream.getTracks().forEach(track => track.stop());
                document.getElementById('voiceRecording').style.display = 'none';
            };
            
            mediaRecorder.start();
            document.getElementById('voiceRecording').style.display = 'flex';
        } catch (err) {
            showToast('❌ خطأ', 'لا يمكن الوصول إلى الميكروفون');
        }
    }
    
    function stopVoiceRecording() {
        if (mediaRecorder && mediaRecorder.state === 'recording') {
            mediaRecorder.stop();
        }
    }
    
    // ========== دوال العملات ==========
    async function updateWalletDisplay() {
        const response = await fetch('/api/user/stats');
        if (response.ok) {
            const data = await response.json();
            document.getElementById('walletGold').innerText = data.gold;
            document.getElementById('walletGems').innerText = data.gems;
            document.getElementById('shopGold').innerText = data.gold;
            document.getElementById('shopGems').innerText = data.gems;
        }
    }
    
    // إضافة الذهب التلقائي كل دقيقة
    setInterval(async () => {
        await fetch('/api/gold/auto', { method: 'POST' });
    }, 60000);
    
    // إضافة الجواهر التلقائي كل نصف ساعة
    setInterval(async () => {
        await fetch('/api/gems/auto', { method: 'POST' });
    }, 1800000);
    
    // ========== دوال المسابقات ==========
    async function loadContest() {
        const response = await fetch('/api/contest/active');
        if (response.ok) {
            const data = await response.json();
            if (data.question) {
                document.getElementById('contestQuestion').innerHTML = data.question;
                if (data.hint) {
                    document.getElementById('contestQuestion').innerHTML += `<div class="system-msg" style="margin-top: 10px;">💡 تلميح: ${data.hint}</div>`;
                }
            } else {
                document.getElementById('contestQuestion').innerHTML = 'لا توجد مسابقة نشطة حالياً';
            }
        }
    }
    
    async function submitContestAnswer() {
        const answer = document.getElementById('contestAnswer').value.trim();
        if (!answer) return;
        
        const response = await fetch('/api/contest/submit', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ answer: answer })
        });
        const data = await response.json();
        
        if (data.correct) {
            document.getElementById('contestResult').innerHTML = '<div class="system-msg" style="color: #7eb311;">✅ إجابة صحيحة! +' + data.reward + ' ذهب</div>';
            updateWalletDisplay();
        } else {
            document.getElementById('contestResult').innerHTML = '<div class="system-msg" style="color: #dc2626;">❌ إجابة خاطئة، حاول مرة أخرى</div>';
        }
        document.getElementById('contestAnswer').value = '';
        setTimeout(() => {
            document.getElementById('contestResult').innerHTML = '';
        }, 3000);
    }
    
    // ========== دوال إضافية ==========
    function showToast(title, message) {
        const toast = document.createElement('div');
        toast.className = 'toast-notification';
        toast.innerHTML = `<strong>${title}</strong><br><small>${message}</small>`;
        document.body.appendChild(toast);
        setTimeout(() => toast.remove(), 4000);
    }
    
    function openModal(modalId) {
        document.getElementById(modalId).classList.add('show');
    }
    
    function closeAllModals() {
        document.querySelectorAll('.modal').forEach(m => m.classList.remove('show'));
    }
    
    // ========== تحميل البيانات ==========
    async function loadUserStats() {
        const response = await fetch('/api/user/stats');
        if (response.ok) {
            currentUser = await response.json();
            document.getElementById('profileEmoji').innerHTML = currentUser.profile_picture || '👤';
            // تحديث الإعدادات المحفوظة
            if (currentUser.name_color) {
                document.documentElement.style.setProperty('--primary', currentUser.name_color);
            }
        }
    }
    
    async function loadOnlineUsers() {
        const response = await fetch('/api/online-users');
        if (response.ok) {
            const users = await response.json();
            const container = document.getElementById('membersList');
            if (container) {
                container.innerHTML = users.map(user => `
                    <div class="user-item" onclick="openUserMenu(${user.id}, '${user.username}')">
                        <div class="user-status"></div>
                        <div style="flex: 1;">${escapeHtml(user.username)}</div>
                        <div>${getRoleIcon(user.role)}</div>
                    </div>
                `).join('');
            }
        }
    }
    
    async function loadRooms() {
        const response = await fetch('/api/rooms');
        if (response.ok) {
            const rooms = await response.json();
            const container = document.getElementById('roomsList');
            if (container) {
                container.innerHTML = rooms.map(room => `
                    <div class="sidebar-item" onclick="changeRoom('${room.name}')">
                        ${room.icon} ${room.display_name}
                        <span style="margin-right: auto; font-size: 12px;">👥 ${room.users_count}</span>
                    </div>
                `).join('');
            }
        }
    }
    
    async function loadShop() {
        const response = await fetch('/api/gifts');
        if (response.ok) {
            const gifts = await response.json();
            const container = document.getElementById('shopItems');
            if (container) {
                container.innerHTML = gifts.map(gift => `
                    <div class="sidebar-item" onclick="buyGift(${gift.id}, '${gift.name}', ${gift.price_gold}, ${gift.price_gems})">
                        ${gift.icon} ${gift.name} - ${gift.price_gold}🪙 / ${gift.price_gems}💎
                    </div>
                `).join('');
            }
        }
    }
    
    async function loadNotifications() {
        const response = await fetch('/api/notifications');
        if (response.ok) {
            const notifs = await response.json();
            const container = document.getElementById('notificationsList');
            if (container) {
                container.innerHTML = notifs.map(n => `
                    <div class="sidebar-item" style="${n.is_read ? 'opacity: 0.6;' : ''}">
                        <strong>${escapeHtml(n.title)}</strong><br>
                        <small>${escapeHtml(n.content)}</small><br>
                        <small style="color: #888;">${new Date(n.created_at).toLocaleString()}</small>
                    </div>
                `).join('');
            }
        }
    }
    
    // ========== دوال الصداقات والهدايا ==========
    async function sendGift(userId, giftId, goldAmount, gemsAmount) {
        const response = await fetch('/api/send-gift', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ to_user_id: userId, gift_id: giftId, gold_amount: goldAmount, gems_amount: gemsAmount, message: document.getElementById('giftMessage').value })
        });
        const data = await response.json();
        if (data.success) {
            showToast('🎁 هدية', 'تم إرسال الهدية بنجاح');
            updateWalletDisplay();
            closeAllModals();
        } else {
            showToast('❌ خطأ', data.error);
        }
    }
    
    // ========== رفع الصور ==========
    document.getElementById('attachBtn')?.addEventListener('click', () => {
        const input = document.createElement('input');
        input.type = 'file';
        input.accept = 'image/*';
        input.onchange = async (e) => {
            const file = e.target.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = (event) => {
                    pendingImage = event.target.result;
                    document.getElementById('previewImage').src = pendingImage;
                    openModal('imagePreviewModal');
                };
                reader.readAsDataURL(file);
            }
        };
        input.click();
    });
    
    document.getElementById('sendImageBtn')?.addEventListener('click', async () => {
        if (pendingImage) {
            socket.emit('send_message', { room: currentRoom, message: pendingImage, type: 'image' });
            closeAllModals();
            pendingImage = null;
        }
    });
    
    // ========== يوتيوب ==========
    async function searchYouTube() {
        const query = document.getElementById('youtubeSearchInput').value;
        if (!query) return;
        
        // API مجاني للبحث (بدون مفتاح - استخدام خدمة بديلة)
        const response = await fetch(`https://www.googleapis.com/youtube/v3/search?part=snippet&maxResults=10&q=${encodeURIComponent(query)}&key=YOUR_API_KEY`);
        if (response.ok) {
            const data = await response.json();
            const container = document.getElementById('youtubeResults');
            container.innerHTML = data.items.map(item => `
                <div class="youtube-video" onclick="playYouTubeVideo('${item.id.videoId}')">
                    <img src="${item.snippet.thumbnails.medium.url}">
                    <div class="youtube-video-info">
                        <h4>${escapeHtml(item.snippet.title)}</h4>
                        <p>${escapeHtml(item.snippet.channelTitle)}</p>
                    </div>
                </div>
            `).join('');
        }
    }
    
    function playYouTubeVideo(videoId) {
        const player = document.getElementById('videoPlayer');
        const iframe = document.getElementById('youtubeIframe');
        iframe.src = `https://www.youtube.com/embed/${videoId}?autoplay=1`;
        player.style.display = 'block';
        document.getElementById('youtubeResults').style.display = 'none';
    }
    
    function closeVideoPlayer() {
        document.getElementById('videoPlayer').style.display = 'none';
        document.getElementById('youtubeIframe').src = '';
        document.getElementById('youtubeResults').style.display = 'block';
    }
    
    // ========== التسجيل والخروج ==========
    async function logout() {
        await fetch('/api/logout', { method: 'POST' });
        window.location.href = '/';
    }
    
    // ========== التهيئة عند تحميل الصفحة ==========
    document.addEventListener('DOMContentLoaded', async () => {
        initSocket();
        await loadUserStats();
        updateWalletDisplay();
        loadOnlineUsers();
        loadRooms();
        loadShop();
        loadNotifications();
        loadContest();
        
        // أحداث الأزرار
        document.getElementById('sendBtn')?.addEventListener('click', sendMessage);
        document.getElementById('messageInput')?.addEventListener('keypress', (e) => {
            if (e.key === 'Enter') sendMessage();
            else sendTyping();
        });
        document.getElementById('voiceBtn')?.addEventListener('click', startVoiceRecording);
        document.getElementById('stopRecordingBtn')?.addEventListener('click', stopVoiceRecording);
        document.getElementById('logoutBtn')?.addEventListener('click', logout);
        document.getElementById('refreshPageBtn')?.addEventListener('click', () => location.reload());
        document.getElementById('youtubeBtn')?.addEventListener('click', () => openModal('youtubeModal'));
        document.getElementById('menuBtn')?.addEventListener('click', () => document.getElementById('sidebar').classList.add('open'));
        document.getElementById('closeSidebar')?.addEventListener('click', () => document.getElementById('sidebar').classList.remove('open'));
        document.getElementById('settingsBtn')?.addEventListener('click', () => openModal('settingsModal'));
        document.getElementById('diamondBtn')?.addEventListener('click', () => openModal('diamondModal'));
        document.getElementById('notifBtn')?.addEventListener('click', () => openModal('notifModal'));
        document.getElementById('profileBtn')?.addEventListener('click', () => openModal('profileModal'));
        
        // إغلاق النوافذ
        document.querySelectorAll('.close-modal, [data-close]').forEach(btn => {
            btn.addEventListener('click', (e) => {
                const modalId = btn.getAttribute('data-close');
                if (modalId) document.getElementById(modalId)?.classList.remove('show');
                else btn.closest('.modal')?.classList.remove('show');
            });
        });
        
        document.querySelectorAll('[data-modal]').forEach(el => {
            el.addEventListener('click', () => {
                const modalId = el.getAttribute('data-modal');
                if (modalId) openModal(modalId);
            });
        });
        
        // تحديث كل 5 ثواني قائمة المتواجدين
        setInterval(loadOnlineUsers, 5000);
        
        // منع الإغلاق العرضي
        window.onclick = (e) => {
            if (e.target.classList.contains('modal')) {
                e.target.classList.remove('show');
            }
        };
    });
    
    function changeRoom(roomName) {
        joinRoom(roomName);
        closeAllModals();
        document.getElementById('sidebar')?.classList.remove('open');
    }
    
    function saveProfile() {
        // حفظ الملف الشخصي
        showToast('✅ تم الحفظ', 'تم تحديث الملف الشخصي');
        closeAllModals();
    }
    
    function playYouTubeVideoFromId(videoId) {
        const playerContainer = document.createElement('div');
        playerContainer.style.cssText = 'position: fixed; bottom: 100px; right: 20px; width: 300px; background: #000; border-radius: 15px; z-index: 2000;';
        playerContainer.innerHTML = `
            <iframe width="100%" height="180" src="https://www.youtube.com/embed/${videoId}?autoplay=1" frameborder="0" allowfullscreen></iframe>
            <button style="position: absolute; top: 5px; right: 5px; background: red; color: white; border: none; border-radius: 50%; width: 25px; height: 25px; cursor: pointer;" onclick="this.parentElement.remove()">✕</button>
        `;
        document.body.appendChild(playerContainer);
    }
    
    function changeRadioStation(url) {
        document.getElementById('radioPlayer').src = url;
        document.getElementById('radioPlayer').play();
    }
    
    function showTypingIndicator(username) {
        const indicator = document.getElementById('typingIndicator');
        indicator.style.display = 'flex';
        indicator.querySelector('span:first-child').innerHTML = `${escapeHtml(username)} يكتب...`;
        setTimeout(() => hideTypingIndicator(), 3000);
    }
    
    function hideTypingIndicator() {
        document.getElementById('typingIndicator').style.display = 'none';
    }
</script>
</body>
</html>
